# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
HOST=0.0.0.0
PORT=5000

# Database Configuration
DATABASE_TYPE=excel

# Excel Configuration
EXCEL_DATA_PATH=./data/customers.xlsx
EXCEL_FOLLOW_UP_PATH=./data/follow_ups.xlsx
EXCEL_DAILY_TASK_PATH=./data/daily_tasks.xlsx

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=customer_manager

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
